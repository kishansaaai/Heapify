# ── LLM provider (first one set wins) ────────────────────────────────────────
# Option A: Google Gemini (easiest for local dev — get key at aistudio.google.com)
GEMINI_API_KEY=AIza...

# Option B: Direct Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Option C: GitLab AI Gateway (auto-injected in CI — leave blank for local dev)
AI_FLOW_AI_GATEWAY_URL=
AI_FLOW_AI_GATEWAY_TOKEN=

# ── GitLab ───────────────────────────────────────────────────────────────────
GITLAB_TOKEN=glpat-...
GITLAB_PROJECT_ID=12345678
# GITLAB_URL defaults to https://gitlab.com — override only for self-managed instances
# CI_SERVER_URL=https://gitlab.example.com

# ── redAgent ─────────────────────────────────────────────────────────────────
# Set to ON to skip real Claude calls and use hardcoded mock responses
REDAGENT_MOCK=OFF
# Optional: custom SQLite database path (default: redAgent.db)
# REDAGENT_DB_PATH=redAgent.db
